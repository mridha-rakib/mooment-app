{
  "expo": {
    "name": "Mooments",
    "slug": "Mooments",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "mooments",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mooments.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0E0D12",
        "foregroundImage": "./assets/images/logo.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "predictiveBackGestureEnabled": false,
      "package": "com.mooments.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-navigation-bar",
        {
          "enforceContrast": false,
          "hidden": false,
          "style": "dark"
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Splash-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0E0D12",
          "dark": {
            "backgroundColor": "#0E0D12"
          }
        }
      ],
      "expo-font",
      "expo-image",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Mooments to use your location to show events near you."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Mooments to use your camera to create stories.",
          "microphonePermission": "Allow Mooments to record audio for story videos.",
          "recordAudioAndroid": true
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-video",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Mooments to record audio for your moments.",
          "enableBackgroundPlayback": false
        }
      ],
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox"
        }
      ],
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#0E0D12",
          "defaultChannel": "messages"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
        "eas": {
          "projectId": "96741709-c195-41c9-bd5b-95e1a9755b79"
        }
      }
  }
}
